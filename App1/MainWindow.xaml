<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="App1.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App1"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Title="Smart Listen">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <muxc:CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <muxc:AppBarButton x:Name="OpenButton" Icon="OpenFile" Label="打开音频" Click="OpenButton_Click"/>
            <muxc:AppBarButton x:Name="UpdateButton" Icon="Refresh" Label="更新进度" Click="UpdateButton_Click"/>
            <muxc:AppBarSeparator/>
        </muxc:CommandBar>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="24" Spacing="24">
                <muxc:InfoBar x:Name="InfoBar" Severity="Informational" IsOpen="True"
                    Title="欢迎使用 Smart Listen"
                    Message="请点击上方按钮打开音频文件开始播放"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <StackPanel Spacing="16">
                        <TextBlock x:Name="FileNameText" Text="未选择文件" 
                                   Style="{ThemeResource TitleTextBlockStyle}" 
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="DurationText" Text="时长: --:--" 
                                   Style="{ThemeResource BodyTextBlockStyle}"/>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <TextBlock x:Name="LyricsText" Text="歌词/文本将在这里显示" 
                               Style="{ThemeResource BodyTextBlockStyle}"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" 
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Padding="16,12" Spacing="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="CurrentTimeText" Text="0:00" 
                               VerticalAlignment="Center"
                               Style="{ThemeResource CaptionTextBlockStyle}"/>
                    <Slider Grid.Column="1" x:Name="ProgressSlider" 
                            Margin="12,0"
                            Minimum="0" Maximum="100" Value="0"
                            ValueChanged="ProgressSlider_ValueChanged"/>
                    <TextBlock Grid.Column="2" x:Name="TotalTimeText" Text="0:00" 
                               VerticalAlignment="Center"
                               Style="{ThemeResource CaptionTextBlockStyle}"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="PlayPauseButton" Width="48" Height="48" 
                                Padding="0" Click="PlayPauseButton_Click">
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE768;"/>
                        </Button>
                        <Button x:Name="StopButton" Width="40" Height="40" 
                                Padding="0" Click="StopButton_Click">
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE71A;"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE767;" 
                                  VerticalAlignment="Center"/>
                        <Slider x:Name="VolumeSlider" Width="120" Minimum="0" Maximum="100" Value="50"
                                ValueChanged="VolumeSlider_ValueChanged"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
