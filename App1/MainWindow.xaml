<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="SmartListen.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SmartListen"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Title="Smart Listen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 主内容区域 - 专辑封面和歌词 -->
        <Grid Grid.Row="0" Background="#1A1A1A">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 专辑封面区域 -->
            <Grid Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="300" Height="300" CornerRadius="8" Background="#2D2D2D">
                    <Grid>
                        <FontIcon Glyph="&#xE8D6;" FontSize="120" Foreground="#666666" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- 歌曲信息 -->
            <StackPanel Grid.Row="1" Margin="24" HorizontalAlignment="Center">
                <TextBlock x:Name="SongTitleText" Text="歌曲标题" 
                           FontSize="28" FontWeight="SemiBold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock x:Name="ArtistText" Text="艺术家" 
                           FontSize="18" Foreground="#AAAAAA"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- 底部播放控制栏 -->
        <Border Grid.Row="1" Background="#2D2D2D" Padding="16,12">
            <StackPanel Spacing="8">
                <!-- 进度条 -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CurrentTimeText" Grid.Column="0" Text="0:00" 
                               Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center"/>
                    <Slider x:Name="ProgressSlider" Grid.Column="1" Margin="12,0"
                            Minimum="0" Maximum="100" Value="0"
                            ValueChanged="ProgressSlider_ValueChanged"/>
                    <TextBlock x:Name="TotalTimeText" Grid.Column="2" Text="0:00" 
                               Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center"/>
                </Grid>

                <!-- 播放控制按钮 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧控制 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" 
                                HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button x:Name="ShuffleButton" Width="36" Height="36" 
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <FontIcon Glyph="&#xE8B1;" FontSize="16" Foreground="#AAAAAA"/>
                        </Button>
                        <Button x:Name="PreviousButton" Width="36" Height="36" 
                                Background="Transparent" BorderThickness="0" Padding="0" 
                                Click="PreviousButton_Click">
                            <FontIcon Glyph="&#xE892;" FontSize="20" Foreground="White"/>
                        </Button>
                    </StackPanel>

                    <!-- 中间播放按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" 
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="RewindButton" Width="40" Height="40" 
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <FontIcon Glyph="&#xE893;" FontSize="20" Foreground="White"/>
                        </Button>
                        <Button x:Name="PlayPauseButton" Width="64" Height="64" 
                                Background="White" BorderThickness="0" CornerRadius="32"
                                Click="PlayPauseButton_Click">
                            <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="28" Foreground="Black"/>
                        </Button>
                        <Button x:Name="ForwardButton" Width="40" Height="40" 
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <FontIcon Glyph="&#xE894;" FontSize="20" Foreground="White"/>
                        </Button>
                    </StackPanel>

                    <!-- 右侧控制 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="RepeatButton" Width="36" Height="36" 
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <FontIcon Glyph="&#xE8EE;" FontSize="16" Foreground="#AAAAAA"/>
                        </Button>
                        <Button x:Name="VolumeButton" Width="36" Height="36" 
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <FontIcon Glyph="&#xE767;" FontSize="16" Foreground="#AAAAAA"/>
                        </Button>
                        <Slider x:Name="VolumeSlider" Width="100" Minimum="0" Maximum="100" Value="50"
                                ValueChanged="VolumeSlider_ValueChanged"/>
                        <Button x:Name="OpenFileButton" Width="36" Height="36" 
                                Background="Transparent" BorderThickness="0" Padding="0"
                                Click="OpenFileButton_Click">
                            <FontIcon Glyph="&#xE8E5;" FontSize="16" Foreground="#AAAAAA"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
